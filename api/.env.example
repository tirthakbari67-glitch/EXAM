# ── Supabase Infrastructure ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ── Security & Sessions ────────────────────────────────────────
JWT_SECRET=generate-a-secure-256bit-key-for-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=90
ADMIN_SECRET=admin@examguard2024

# ── AI Spectral Parser (Inception AI) ──────────────────────────
# Get your key at https://www.inceptionlabs.ai/
INCEPTION_API_KEY=your-inception-labs-api-key
AI_MODEL=mercury-2

# ── Network ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
PORT=8000
